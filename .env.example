# Production Environment Configuration
# ==================================

# Build Information
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
VCS_REF=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
VERSION=1.0.0

# Environment
ENVIRONMENT=production
APP_NAME="Locker Phycer"
DEBUG=false

# Security Keys (Generate new ones for production)
SECRET_KEY=
AI_CITIZENSHIP_SECRET=
ENCRYPTION_KEY=

# Database Configuration
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://lockerphycer_user:@postgres:5432/lockerphycer_production

# Redis Configuration
REDIS_PASSWORD=
REDIS_URL=redis://:redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/0

# Application URLs
API_HOST_PORT=8010
FRONTEND_URL=https://your-domain.com
API_URL=https://api.your-domain.com

# AI Provider Keys
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=

# Billing & Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Monitoring — Sentry Error Tracking & Performance
# ─────────────────────────────────────────────────
# REQUIRED for Sentry to activate.  Without this the SDK is a silent no-op.
# 1. Go to https://sentry.io → Settings → Projects → <your project> → Client Keys (DSN)
# 2. Copy the DSN (format: https://xxx@oXXX.ingest.sentry.io/XXXX)
# 3. Paste it below.
# traces_sample_rate is hardcoded to 1.0 in main.py — lower it (e.g. 0.1) in
# high-traffic production once you have a baseline in the Performance tab.
SENTRY_DSN=
# Controls the "Environment" tag in Sentry (production | staging | development)
SENTRY_ENVIRONMENT=production

# Grafana / Prometheus
GRAFANA_PASSWORD=

# Email Configuration (Resend)
RESEND_API_KEY=
EMAIL_FROM="Veklom <noreply@veklom.com>"

# Legacy SMTP (optional fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# Storage Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Security Settings
ENABLE_MFA=true
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=120

# Performance Settings
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT_SECONDS=30
CACHE_TTL_SECONDS=3600

# AI/ML Configuration
MODEL_CACHE_DIR=/app/models
MAX_CONCURRENT_AI_REQUESTS=10
AI_REQUEST_TIMEOUT_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs/lockerphycer.log

# OpenTelemetry / Grafana Cloud Application Observability
# Get your OTLP credentials from Grafana Cloud → Connections → OpenTelemetry
OTEL_SERVICE_NAME=veklom-sovereign-ai-hub
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-encoded-instanceID:apiKey>
